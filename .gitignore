# ──────────────────────────────────────────────────────────────────────────
# EHVRM-System .gitignore
# ──────────────────────────────────────────────────────────────────────────

# ── SECRETS — NEVER COMMIT THESE ──────────────────────────────────────────
backend/.env
frontend/.env
database/firebase/serviceAccountKey.json
*.pem
*.key

# ── PYTHON ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ── NODE ──────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── VITE ──────────────────────────────────────────────────────────────────
frontend/.vite/

# ── OS FILES ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml

# ── DOCKER ────────────────────────────────────────────────────────────────
.docker/

# ── LOGS ──────────────────────────────────────────────────────────────────
*.log
logs/
